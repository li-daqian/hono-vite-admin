// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

model User {
  id                  String     @id @default(ulid())
  username            String     @unique
  password            String
  salt                String
  email               String?
  phone               String?
  displayName         String?    @map("display_name")
  status              UserStatus @default(ACTIVE)
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  departments   UserDepartment[]
  roles         UserRole[]
  refreshTokens RefreshToken[]

  @@map("user")
}

model Department {
  id        String           @id @default(ulid())
  parentId  String?          @map("parent_id")
  name      String
  leader    String?
  phone     String?
  email     String?
  order     Int              @default(0)
  status    DepartmentStatus @default(ACTIVE)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  users UserDepartment[]

  @@index([parentId])
  @@index([status])
  @@map("department")
}

model UserDepartment {
  userId       String @map("user_id")
  departmentId String @map("department_id")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
  @@index([departmentId])
  @@map("user_department")
}

model Role {
  id          String  @id @default(ulid())
  name        String  @unique
  description String?

  userRoles   UserRole[]
  permissions RolePermission[]

  @@map("role")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_role")
}

model Permission {
  id       String         @id @default(ulid())
  type     PermissionType
  targetId String         @map("target_id")

  rolePermissions RolePermission[]

  @@unique([type, targetId])
  @@map("permission")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permission")
}

model Menu {
  id       String  @id @default(ulid())
  parentId String? @map("parent_id")
  name     String
  path     String?
  order    Int

  actions Action[]

  @@index([parentId])
  @@map("menu")
}

model Action {
  id          String  @id @default(ulid())
  menuId      String  @map("menu_id")
  name        String
  description String?

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId])
  @@map("action")
}

model SysConfig {
  key   String @id
  value String

  @@map("sys_config")
}

model RefreshToken {
  id        String   @id @default(ulid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_token")
}

model AuditLog {
  id                  String        @id @default(ulid())
  category            AuditCategory @default(OPERATION)
  module              String
  action              String
  operatorId          String?       @map("operator_id")
  operatorUsername    String        @map("operator_username")
  operatorDisplayName String?       @map("operator_display_name")
  method              String
  path                String
  ip                  String?
  userAgent           String?       @map("user_agent")
  requestId           String        @map("request_id")
  requestSnapshot     Json?         @map("request_snapshot")
  createdAt           DateTime      @default(now()) @map("created_at")

  @@index([category, createdAt])
  @@index([module, createdAt])
  @@index([operatorId])
  @@index([createdAt])
  @@map("audit_log")
}

enum UserStatus {
  ACTIVE
  DISABLED

  @@map("user_status")
}

enum DepartmentStatus {
  ACTIVE
  DISABLED

  @@map("department_status")
}

enum PermissionType {
  MENU
  ACTION

  @@map("permission_type")
}

enum AuditCategory {
  LOGIN
  OPERATION

  @@map("audit_category")
}
